---
import type { PostEntry } from '~/lib/tags';

interface Props {
  entry: PostEntry;
}

const { entry } = Astro.props;
const url = `/writing/${entry.id}/`;
const teaser = entry.data.excerpt;
---

<a href={url} class="sidebar-post-link">
  <span class="sidebar-post-title">{entry.data.title}</span>
  {teaser && <span class="sidebar-post-teaser">{teaser}</span>}
</a>
