---
import BaseLayout from '~/layouts/BaseLayout.astro';
import PostCardFeatured from '~/components/PostCardFeatured.astro';
import SidebarPostLink from '~/components/SidebarPostLink.astro';
import { getAllPosts } from '~/lib/ghost';

const allPosts = await getAllPosts();
const featuredPosts = allPosts.filter((p) => p.featured);
const heroPost = featuredPosts[0] ?? allPosts[0];
const sidebarPosts = (featuredPosts.length > 0 ? featuredPosts.slice(1, 6) : allPosts.slice(1, 6));
---

<BaseLayout
  title="Jeremy Fuksa — The Cocktail Napkin"
  description="Design systems, UX strategy, and AI design pipeline infrastructure. Senior IC through Director. Kansas City, remote-friendly."
>
  <div class="home-bg">

  <section class="hero">
    <div class="hero-inner">
      <h1 class="hero-name">Jeremy Fuksa</h1>
      <p class="hero-positioning">Senior IC through Director. Design systems, UX strategy, and the AI design pipeline work that ties them together &mdash; RAG, vector databases, MCP, and the institutional knowledge that has to feed them. Built at Cerner and Oracle Health. Open to teams anywhere from Kansas City.</p>
    </div>
  </section>

  <section class="featured-work">
    <div class="featured-work-inner">
      <div class="featured-work-grid">
        <a href="/work/domain-foundation/" class="featured-work-card">
          <span class="featured-work-label">Methodology</span>
          <h2 class="featured-work-title">Domain Foundation</h2>
          <p class="featured-work-body">Encoding institutional design expertise as layered, machine-readable knowledge an AI can reason with. Because default models produce default output.</p>
          <span class="featured-work-link">Read the case study &rarr;</span>
        </a>

        <a href="/work/moonbird/" class="featured-work-card">
          <span class="featured-work-label">Case study</span>
          <h2 class="featured-work-title">Moonbird</h2>
          <p class="featured-work-body">A year building a RAG pipeline &mdash; vector database, MCP server, Figma Make integration &mdash; to generate design-system-aligned UI inside Oracle Health. The research that became Domain Foundation.</p>
          <span class="featured-work-link">Read the case study &rarr;</span>
        </a>

        <a href="/work/terra-design-system/" class="featured-work-card">
          <span class="featured-work-label">Case study</span>
          <h2 class="featured-work-title">Terra Design System</h2>
          <p class="featured-work-body">Open-source React component library at Cerner. 80+ components, 200+ icons, WCAG 2.1 AA, Apache 2.0. UX designer working directly in the React codebase alongside engineering.</p>
          <span class="featured-work-link">Read the case study &rarr;</span>
        </a>
      </div>
      <a href="/work/" class="featured-work-all">See all work &rarr;</a>
    </div>
  </section>

  <section class="testimonial">
    <div class="testimonial-inner">
      <span class="testimonial-label">What people say</span>
      <div class="testimonial-grid">
        <figure class="testimonial-item">
          <blockquote class="testimonial-quote">
            <p>Jeremy was the rare soul you meet in business. Very few designers I have encountered (and I have worked with many) have his technical acumen. During this agentic era, he took on a difficult initiative to prove a hypothesis with design and AI. He effectively pivoted when technology opportunities arose that made more business sense. He led a team to drive results and inspired those around him. I would recommend him to any situation where advanced technology and design converge.</p>
          </blockquote>
          <figcaption class="testimonial-cite">
            <span class="testimonial-cite-name">Douglas Liles</span>
            <span class="testimonial-cite-title">Senior Principal Product Manager, Oracle Health</span>
          </figcaption>
        </figure>
        <figure class="testimonial-item">
          <blockquote class="testimonial-quote">
            <p>I&rsquo;ve had the privilege of collaborating with Jeremy over seven years, watching him grow into an exceptionally thoughtful design systems leader. At Oracle Health, he built and managed teams that didn&rsquo;t just deliver&mdash;they thrived. His deep expertise spans design systems, web applications, and most recently, how AI can meaningfully enhance our design processes. What sets Jeremy apart is his genuine collaborative spirit paired with real technical depth. He&rsquo;s the kind of leader who makes those around him better.</p>
          </blockquote>
          <figcaption class="testimonial-cite">
            <span class="testimonial-cite-name">Micah Sonderman, UXC</span>
            <span class="testimonial-cite-title">Healthcare UX Leader, Oracle Health</span>
          </figcaption>
        </figure>
      </div>
    </div>
  </section>

  <div class="home-writing-grid">
    <main>
      <span class="section-title">Latest</span>
      {heroPost && <PostCardFeatured post={heroPost} />}
    </main>

    <aside class="sidebar">
      <span class="section-title">Previous Writing</span>
      <nav class="sidebar-posts">
        {sidebarPosts.map((post) => <SidebarPostLink post={post} />)}
        <a href="/writing/" class="sidebar-posts-all">All posts &rarr;</a>
      </nav>
    </aside>
  </div>

  </div>
</BaseLayout>
