---
import type { GetStaticPaths } from 'astro';
import { render } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import PostLayout from '~/components/PostLayout.astro';
import PostCard from '~/components/PostCard.astro';
import { getAllPostsSorted, tagSlug, type PostEntry } from '~/lib/tags';
import { shortDate } from '~/lib/format';

export const getStaticPaths = (async () => {
  const posts = await getAllPostsSorted();
  return posts.map((entry) => ({
    params: { slug: entry.id },
    props: { entry, allPosts: posts },
  }));
}) satisfies GetStaticPaths;

const { entry, allPosts } = Astro.props as {
  entry: PostEntry;
  allPosts: PostEntry[];
};
const { data } = entry;
const { Content, remarkPluginFrontmatter } = await render(entry);
const readingMinutes = data.readingTime ?? remarkPluginFrontmatter?.minutesRead;

const primaryTag = data.tags[0];
const primaryTagSlug = primaryTag ? tagSlug(primaryTag) : null;
const related = primaryTagSlug
  ? allPosts
      .filter(
        (p) =>
          p.id !== entry.id &&
          p.data.tags.some((t) => tagSlug(t) === primaryTagSlug),
      )
      .slice(0, 3)
  : [];

const more = allPosts.filter((p) => p.id !== entry.id).slice(0, 3);
---

<BaseLayout
  title={`${data.title} — Jeremy Fuksa`}
  description={data.excerpt}
>
  <PostLayout
    title={data.title}
    excerpt={data.excerpt}
    publishedAt={data.publishedAt}
    updatedAt={data.updatedAt}
    tags={data.tags}
    author={data.author}
    readingMinutes={readingMinutes}
    coverImage={data.coverImage}
    coverImageAlt={data.coverImageAlt}
    coverImageCaption={data.coverImageCaption}
    isDraft={data.draft}
  >
    <Content />

    <Fragment slot="sidebar">
      {related.length > 0 && (
        <>
          <div class="post-sidebar-title">Related</div>
          {related.map((r) => (
            <div class="post-card">
              <a href={`/writing/${r.id}/`}>
                <h4 class="post-card-title">{r.data.title}</h4>
              </a>
              <span class="post-card-date">{shortDate(r.data.publishedAt)}</span>
            </div>
          ))}
        </>
      )}
    </Fragment>
  </PostLayout>

  <footer class="post-footer">
    <div class="post-footer-title">More writing</div>
    {more.map((m) => <PostCard entry={m} />)}
  </footer>
</BaseLayout>
