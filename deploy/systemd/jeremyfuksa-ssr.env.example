# /etc/jeremyfuksa-ssr.env  (install as root:root mode 0600)
#
# Read by systemd (EnvironmentFile=) and passed to the Node SSR process.
# Credentials never live in this repo — copy this file to /etc/ on the
# droplet, fill in real values, then `sudo systemctl restart jeremyfuksa-ssr`.
#
# Without these, /api/tinkering.json returns HTTP 200 with all-null fields —
# the documented degraded-but-working state.

# GitHub personal access token, public_repo scope (read-only).
GITHUB_TOKEN=

# Nabu Casa base URL, no trailing slash.
HA_URL=

# Home Assistant long-lived access token.
HA_TOKEN=

# Entity IDs from HA → Developer Tools → States.
HA_TEMP_ENTITY=
HA_MEDIA_ENTITY=
