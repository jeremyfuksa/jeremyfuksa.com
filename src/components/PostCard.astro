---
import { Image } from 'astro:assets';
import type { PostEntry } from '~/lib/tags';
import { isoDate, shortDate, readingTime } from '~/lib/format';

interface Props {
  entry: PostEntry;
}

const { entry } = Astro.props;
const { data } = entry;
const url = `/writing/${entry.id}/`;
const readtime = readingTime(data.readingTime);
---

<article class={`post-card ${data.coverImage ? 'post-card-has-image' : ''}`}>
  {data.coverImage && (
    <div class="post-card-image-col">
      <a href={url} class="post-card-image-link">
        <Image
          class="post-card-image"
          src={data.coverImage}
          alt={data.coverImageAlt ?? ''}
          loading="lazy"
          widths={[320, 480, 720]}
          sizes="(min-width: 720px) 360px, 100vw"
        />
      </a>
      <div class="post-card-meta">
        <span class="post-card-date">
          <time datetime={isoDate(data.publishedAt)}>{shortDate(data.publishedAt)}</time>
        </span>
      </div>
    </div>
  )}
  <div class="post-card-content">
    {!data.coverImage && (
      <div class="post-card-meta">
        <span class="post-card-date">
          <time datetime={isoDate(data.publishedAt)}>{shortDate(data.publishedAt)}</time>
        </span>
      </div>
    )}
    <a href={url}>
      <h3 class="post-card-title">{data.title}</h3>
    </a>
    {data.excerpt && <p class="post-card-excerpt">{data.excerpt}</p>}
    <div class="post-card-footer">
      {readtime && <span class="post-card-readtime">{readtime}</span>}
      <a href={url} class="post-card-read-link">Read <span>&rarr;</span></a>
    </div>
  </div>
</article>
