---
import { Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { readingTime } from '~/lib/format';

interface Props {
  title: string;
  eyebrow: string;
  tagline: string;
  role: string;
  organization?: string;
  timeline: string;
  facts?: { label: string; value: string }[];
  stats?: { value: string; label: string }[];
  links?: { label: string; href: string }[];
  readingMinutes?: number;
  coverImage?: ImageMetadata;
  coverImageAlt?: string;
}

const {
  title,
  eyebrow,
  tagline,
  role,
  organization,
  timeline,
  facts,
  stats,
  links,
  readingMinutes,
  coverImage,
  coverImageAlt,
} = Astro.props;

const readtime = readingTime(readingMinutes);

const baseFacts: { label: string; value: string }[] = [
  { label: 'Role', value: role },
];
if (organization) baseFacts.push({ label: 'Organization', value: organization });
baseFacts.push({ label: 'Timeline', value: timeline });
const factStrip = [...baseFacts, ...(facts ?? [])];
---

<div class="casestudy-page">
  <a href="/work/" class="casestudy-back">← Work</a>

  <header class="casestudy-header">
    <div class="casestudy-eyebrow">{eyebrow}</div>
    <h1 class="casestudy-title">{title}</h1>
    <p class="casestudy-tagline" set:html={tagline}></p>
    <div class="post-header-meta">
      {readtime && <span class="post-card-readtime">{readtime}</span>}
    </div>
  </header>

  <dl class="casestudy-facts">
    {factStrip.map((f) => (
      <div class="casestudy-fact">
        <dt>{f.label}</dt>
        <dd>{f.value}</dd>
      </div>
    ))}
  </dl>

  {stats && stats.length > 0 && (
    <ul class="casestudy-stats">
      {stats.map((s) => (
        <li class="casestudy-stat">
          <span class="casestudy-stat-value">{s.value}</span>
          <span class="casestudy-stat-label">{s.label}</span>
        </li>
      ))}
    </ul>
  )}

  {coverImage && (
    <figure class="casestudy-cover">
      <Picture
        src={coverImage}
        alt={coverImageAlt ?? ''}
        loading="eager"
        decoding="async"
        fetchpriority="high"
        formats={['avif', 'webp']}
        widths={[640, 960, 1280, 1920]}
        sizes="(min-width: 1280px) 1280px, 100vw"
      />
    </figure>
  )}

  <div class="casestudy-prose post-prose">
    <slot />
  </div>

  {links && links.length > 0 && (
    <footer class="casestudy-references">
      <div class="casestudy-references-label">References</div>
      <ul>
        {links.map((l) => (
          <li>
            <a href={l.href} target="_blank" rel="noopener noreferrer">{l.label}</a>
          </li>
        ))}
      </ul>
    </footer>
  )}
</div>
