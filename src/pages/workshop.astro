---
import BaseLayout from '~/layouts/BaseLayout.astro';

interface WorkshopEntry {
  name: string;
  status: string;
  body: string;
  note?: string;
  link?: string;
}

const rightNow: WorkshopEntry[] = [
  {
    name: 'Bearpaw',
    status: 'Active',
    body: 'I’ve got a Uniden Bearcat BCT125 radio scanner. Old Windows apps exist to program and control it. I thought I would build a platform agnostic way of doing everything the Windows apps do. I’m close to a beta, and will be sharing it when it’s ready.',
  },
  {
    name: 'Kerchunk',
    status: 'Active',
    body: 'Bearpaw, but smaller. The Uniden is a pain to hook up to my car’s aux input, so I’m building a scanner that’s half the size and connects over Bluetooth.',
  },
  {
    name: 'Meshtastic KC',
    status: 'Dipping in and out',
    body: 'Started playing with Meshtastic last fall. It’s a communication tool, and the silence threw me — nobody was communicating on it. So I stood up a Discord and a website for the Kansas City mesh. The Discord is almost two hundred people now.',
    note: '<a href="https://kansascitymesh.live/">kansascitymesh.live</a> · <a href="https://discord.gg/unhg3Xfy">Discord</a>',
  },
  {
    name: 'The algorithm experiment',
    status: 'Ongoing',
    body: 'Apple Music had me in a rut. I exported my listening history and used Claude to train the algorithm out of it. West African desert blues and Brazilian music started showing up in rotation.',
    link: '/writing/the-algorithm-and-i-were-in-a-rut/',
  },
  {
    name: 'Amateur Radio: KF0NUI',
    status: 'Warming up',
    body: 'Most active in the spring, sometimes the fall. The other entries on this page are what radio looks like for me — building, not hopping on the air to talk about our collectively bad backs.',
    note: 'Technician licensed, General on the study pile. · <a href="https://www.qrz.com/db/KF0NUI">QRZ</a>',
  },
];

const everythingElse: WorkshopEntry[] = [
  {
    name: 'Campfire',
    status: 'Maintained',
    body: 'My personal design system, on npm. Tokens, typography, a handful of utility patterns.',
    link: 'https://www.npmjs.com/package/@jeremyfuksa/campfire',
  },
  {
    name: 'The Cocktail Napkin',
    status: 'Ongoing',
    body: 'The one thing I’m consistently working on. Check back on me in a few months to see how consistent I’ve been.',
    link: '/writing/',
  },
  {
    name: 'Orange Flame Design',
    status: 'Selective',
    body: 'The freelance practice. UX strategy, product design, the occasional weird project.',
    link: '/work-with-me/',
  },
  {
    name: 'SSTeVe',
    status: 'Shelved',
    body: 'A desktop app for sending images over ham radio. Got distracted by Meshtastic. The code is still there.',
    note: 'Shelved, not abandoned.',
  },
  {
    name: 'Home automations / Claude Cowork',
    status: 'Always tinkering',
    body: 'Home Assistant runs the house. Claude Cowork glues together whatever doesn’t natively talk. I break something here roughly once a month.',
    note: '<a href="https://www.home-assistant.io/">Home Assistant</a>',
  },
];
---

<BaseLayout
  title="Workshop — Jeremy Fuksa"
  description="What I’m working on right now, and the projects that accumulated along the way. Hardware, radio, music, software side projects, writing experiments, archived obsessions."
>
  <article class="workshop-page writing-layout writing-layout-single">
    <div class="page-header">
      <div class="page-header-top">
        <h1>Workshop</h1>
        <span class="page-header-count">Updated May 2026 &middot; Kansas City</span>
      </div>
      <p class="page-header-intro">Hardware, radio, software, writing. Some I’m tinkering with now, some I’ve been tinkering with for years.</p>
    </div>

    <section class="workshop-section" aria-labelledby="right-now-heading">
      <h2 id="right-now-heading" class="workshop-section-title">Right now</h2>
      <p class="workshop-section-sub">What’s got my attention</p>
      <ul class="workshop-entries">
        {rightNow.map((entry) => (
          <li class="workshop-entry">
            <div class="workshop-entry-header">
              {entry.link
                ? <a href={entry.link} class="workshop-entry-name workshop-entry-link">{entry.name}</a>
                : <span class="workshop-entry-name">{entry.name}</span>}
              <span class="workshop-entry-sep" aria-hidden="true">&mdash;</span>
              <span class="workshop-entry-status">{entry.status}</span>
            </div>
            <p class="workshop-entry-body">{entry.body}</p>
            {entry.note && <p class="workshop-entry-note" set:html={entry.note}></p>}
          </li>
        ))}
      </ul>
    </section>

    <section class="workshop-section" aria-labelledby="everything-heading">
      <h2 id="everything-heading" class="workshop-section-title">Everything else</h2>
      <p class="workshop-section-sub">The accumulated work</p>
      <ul class="workshop-entries">
        {everythingElse.map((entry) => (
          <li class="workshop-entry">
            <div class="workshop-entry-header">
              {entry.link
                ? <a href={entry.link} class="workshop-entry-name workshop-entry-link">{entry.name}</a>
                : <span class="workshop-entry-name">{entry.name}</span>}
              <span class="workshop-entry-sep" aria-hidden="true">&mdash;</span>
              <span class="workshop-entry-status">{entry.status}</span>
            </div>
            <p class="workshop-entry-body">{entry.body}</p>
            {entry.note && <p class="workshop-entry-note" set:html={entry.note}></p>}
          </li>
        ))}
      </ul>
    </section>

    <section class="workshop-footnote">
      <p>Projects here are things I do for myself. Client work lives in <a href="/work/">the case studies</a>. Workshop is the mess before the case study exists, and also the stuff that never becomes one.</p>
    </section>
  </article>
</BaseLayout>
