---
import BaseLayout from '~/layouts/BaseLayout.astro';
import PostCard from '~/components/PostCard.astro';
import { getAllPostsSorted } from '~/lib/tags';

const POSTS_PER_PAGE = 5;
const allPosts = await getAllPostsSorted();
const totalPages = Math.ceil(allPosts.length / POSTS_PER_PAGE);
const posts = allPosts.slice(0, POSTS_PER_PAGE);
---

<BaseLayout title="Writing — Jeremy Fuksa" description="Essays and notes on design, AI, and design systems.">
  <div class="writing-layout writing-layout-single">
    <div class="page-header">
      <div class="page-header-top">
        <h1>Writing</h1>
        <span class="page-header-count">{allPosts.length} posts</span>
      </div>
      <p class="page-header-intro">In one form or another, The Cocktail Napkin has been a journal of unbridled creativity for me since 2003. Weclome to version 67.0.</p>
    </div>

    <main>
      {posts.map((entry) => <PostCard entry={entry} />)}

      {totalPages > 1 && (
        <div class="pagination">
          <span class="page-number">Page 1 of {totalPages}</span>
          <a href="/writing/page/2/">Older &rarr;</a>
        </div>
      )}
    </main>
  </div>
</BaseLayout>
