---

<BaseLayout
  title="Resume — Jeremy Fuksa"
  description="Structured career data for Jeremy Fuksa. Design systems, UX strategy, AI design infrastructure. Kansas City."
  bodyClass="resume-body"
>
  <link slot="head" rel="stylesheet" media="print" href="/print-resume.css" />

  <main class="resume">
    <header class="resume-header">
      <h1>Jeremy Fuksa</h1>
      <p class="resume-title">Designer, design systems lead, AI design infrastructure</p>
      <ul class="resume-contact">
        <li>Kansas City, MO</li>
        <li><a href="mailto:hello@jeremyfuksa.com">hello@jeremyfuksa.com</a></li>
        <li><a href="https://linkedin.com/in/jeremyfuksa">LinkedIn</a></li>
        <li><a href="https://github.com/jeremyfuksa">GitHub</a></li>
        <li><a href="https://jeremyfuksa.com">jeremyfuksa.com</a></li>
      </ul>
    </header>

    <section class="resume-section" aria-labelledby="seeking-heading">
      <h2 id="seeking-heading">Currently seeking</h2>
      <ul class="resume-bullets">
        <li><strong>Roles:</strong> Senior IC through Director — Senior Product Designer, Staff, Principal, Design Systems Manager, UX Manager, UX Director.</li>
        <li><strong>Engagement models:</strong> Full-time, contract, or fractional.</li>
        <li><strong>Focus areas:</strong> Design systems, AI design pipelines, and the institutional knowledge layer that connects the two.</li>
        <li><strong>Location:</strong> Remote or hybrid, Kansas City base, no relocation.</li>
      </ul>
    </section>

    <section class="resume-section" aria-labelledby="skills-heading">
      <h2 id="skills-heading">Skills &amp; expertise</h2>
      <div class="resume-skills-grid">
        {skillsByDomain.map((domain) => (
          <div class="resume-skill-block">
            <h3>{domain.heading}</h3>
            <ul>
              {domain.items.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <section class="resume-section" aria-labelledby="experience-heading">
      <h2 id="experience-heading">Experience</h2>
      <ol class="resume-experience">
        {experience.map((role) => (
          <li class="resume-role">
            <header class="resume-role-header">
              <h3 class="resume-role-company">{role.company}</h3>
              <span class="resume-role-dates">
                <time>{role.start}</time>
                <span aria-hidden="true">&ndash;</span>
                <time>{role.end}</time>
              </span>
            </header>
            <p class="resume-role-title">{role.title}</p>
            <ul class="resume-bullets">
              {role.bullets.map((b) => <li>{b}</li>)}
            </ul>
          </li>
        ))}
      </ol>
    </section>

    <section class="resume-section" aria-labelledby="education-heading">
      <h2 id="education-heading">Education</h2>
      <p><strong>Oklahoma State University</strong> &middot; Stillwater, OK</p>
      <p class="resume-muted">Undergraduate studies in mass communications. Self-taught web design (1996 onward). The web is what stuck.</p>
    </section>

    <section class="resume-section" aria-labelledby="side-heading">
      <h2 id="side-heading">Side projects</h2>
      <ul class="resume-side-projects">
        {sideProjects.map((project) => (
          <li>
            <strong>{project.name}</strong> &mdash; {project.body}
          </li>
        ))}
      </ul>
      <p class="resume-muted">Full Workshop at <a href="/workshop/">/workshop/</a>.</p>
    </section>
  </main>
</BaseLayout>
