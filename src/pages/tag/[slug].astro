---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '~/layouts/BaseLayout.astro';
import PostCard from '~/components/PostCard.astro';
import {
  getAllTagsWithCounts,
  getPostsByTagSlug,
  type TagWithCount,
  type PostEntry,
} from '~/lib/tags';

export const getStaticPaths = (async () => {
  const tags = await getAllTagsWithCounts();
  const out = await Promise.all(
    tags.map(async (tag) => ({
      params: { slug: tag.slug },
      props: {
        tag,
        posts: await getPostsByTagSlug(tag.slug),
        allTags: tags,
      },
    })),
  );
  return out;
}) satisfies GetStaticPaths;

const { tag, posts, allTags } = Astro.props as {
  tag: TagWithCount;
  posts: PostEntry[];
  allTags: TagWithCount[];
};
---

<BaseLayout title={`${tag.name} — Jeremy Fuksa`}>
  <div class="writing-layout writing-layout-single">
    <div class="page-header">
      <div class="page-header-left">
        <h1>{tag.name}</h1>
      </div>
      <span class="page-header-count">{posts.length} posts</span>
    </div>

    <div class="filter-bar">
      <a href="/writing/" class="filter-chip">All</a>
      {allTags.map((t) => (
        <a href={`/tag/${t.slug}/`} class={`filter-chip ${t.slug === tag.slug ? 'active' : ''}`}>{t.name}</a>
      ))}
    </div>

    <main>
      {posts.map((entry) => <PostCard entry={entry} />)}
    </main>
  </div>
</BaseLayout>
