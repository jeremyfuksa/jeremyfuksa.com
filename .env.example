# jeremyfuksa.com — environment variables for the tinkering strip
# Copy this file to .env (git-ignored) and fill in real values for local
# development. On the droplet these are set via PM2's ecosystem.config.js.

# GitHub — personal access token, public_repo scope (read-only).
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=

# Home Assistant — Nabu Casa cloud base URL. Format:
# https://[hash].ui.nabu.casa  (no trailing slash)
HA_URL=

# Home Assistant — long-lived access token.
# Generate at: HA → Profile → Long-Lived Access Tokens
HA_TOKEN=

# Home Assistant — backyard temperature sensor entity ID.
# Find it at: HA → Developer Tools → States → filter `sensor`
HA_TEMP_ENTITY=sensor.backyard_temperature

# Home Assistant — media player entity ID for "now playing".
# Find it at: HA → Developer Tools → States → filter `media_player`
HA_MEDIA_ENTITY=media_player.apple_music
